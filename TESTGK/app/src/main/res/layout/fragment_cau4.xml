<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OẲN TÙ TÌ"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E91E63"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_Score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Máy: 0  |  Bạn: 0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Máy chọn:"
        android:textSize="16dp"/>

    <TextView
        android:id="@+id/tv_BotChoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖"
        android:textSize="64dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_Result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mời bạn ra chiêu!"
        android:textSize="22dp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3">

        <Button
            android:id="@+id/btn_Keo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✌️ Kéo"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_Bua"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✊ Búa"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_Bao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✋ Bao" />
        <Button
            android:id="@+id/btn_Reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chơi lại từ đầu"
            android:backgroundTint="#607D8B"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</LinearLayout>