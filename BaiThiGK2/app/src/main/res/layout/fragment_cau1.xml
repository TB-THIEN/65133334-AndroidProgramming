<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chuyển đổi Tiền tệ"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#E4420E"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/edtTienVND"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập số tiền VNĐ"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:backgroundTint="#08CFE9"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnChuyenDoi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đổi sang USD"
        android:backgroundTint="#08CFE9"
        android:textColor="@android:color/white"
        android:padding="12dp"/>

    <TextView
        android:id="@+id/txtKetQua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kết quả: 0 USD"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="40dp"
        android:textColor="#E4420E"/>

</LinearLayout>